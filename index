document.getElementById('qtyPlus').addEventListener('click',()=>{if(qty<10){qty++;updateSum()}});
document.getElementById('buyBtn').addEventListener('click',()=>{
  document.querySelectorAll('#ticketBody .step-label,#ticketBody .ticket-matches,#ticketBody .seat-grid,#ticketBody .qty-row,#ticketBody .summary,#ticketBody .buy-btn').forEach(el=>el.style.display='none');
  document.getElementById('ticketSuccess').style.display='block';
  showToast('Bilet başarıyla alındı!');
});

/* MODAL */
function openModal(id){document.getElementById(id).classList.add('open');document.body.style.overflow='hidden'}
function closeModal(id){
  document.getElementById(id).classList.remove('open');document.body.style.overflow='';
  if(id==='ticketModal'){setTimeout(()=>{document.getElementById('ticketSuccess').style.display='none';document.querySelectorAll('#ticketBody .step-label,#ticketBody .ticket-matches,#ticketBody .seat-grid,#ticketBody .qty-row,#ticketBody .summary,#ticketBody .buy-btn').forEach(el=>el.style.display='')},400)}
}
document.getElementById('openTicket').addEventListener('click',()=>openModal('ticketModal'));
document.querySelectorAll('.footer-ticket').forEach(a=>a.addEventListener('click',e=>{e.preventDefault();openModal('ticketModal')}));
document.querySelectorAll('[data-close]').forEach(btn=>btn.addEventListener('click',()=>closeModal(btn.dataset.close)));
document.querySelectorAll('.modal-overlay').forEach(ov=>ov.addEventListener('click',e=>{if(e.target===ov)closeModal(ov.id)}));
document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.modal-overlay.open').forEach(ov=>closeModal(ov.id))});

/* TOAST */
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3500)}
</script>
</body>
</html>
