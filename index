<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Beşiktaş JK — Kartal Yuvası</title>
<link rel="icon" type="image/png" href="https://upload.wikimedia.org/wikipedia/commons/thumb/d/da/BesiktasJK-Logo.svg/330px-BesiktasJK-Logo.svg.png"/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@300;400;600;700&family=Crimson+Pro:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--black:#0a0a0a;--white:#f5f0e8;--gold:#c9a84c;--gold-light:#e8c96a;--red:#cc2222;--green:#3a9e5f;--gray:#1a1a1a;--mid:#242424;--mid2:#2e2e2e}
html{scroll-behavior:smooth}
body{background:var(--black);color:var(--white);font-family:'Oswald',sans-serif;overflow-x:hidden;cursor:none}
.cursor{position:fixed;width:12px;height:12px;background:var(--gold);border-radius:50%;pointer-events:none;z-index:9999;transition:transform .1s ease;transform:translate(-50%,-50%)}
.cursor-ring{position:fixed;width:36px;height:36px;border:1px solid rgba(201,168,76,.5);border-radius:50%;pointer-events:none;z-index:9998;transition:width .3s,height .3s;transform:translate(-50%,-50%)}
nav{position:fixed;top:0;left:0;right:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:1rem 3.5rem;background:rgba(10,10,10,.9);backdrop-filter:blur(16px);border-bottom:1px solid rgba(201,168,76,.15);transition:background .3s}
.nav-logo{display:flex;align-items:center;gap:.8rem;text-decoration:none;cursor:none}
.nav-eagle{height:38px;width:auto;filter:drop-shadow(0 0 8px rgba(201,168,76,.4));animation:floatEagle 3s ease-in-out infinite}
@keyframes floatEagle{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}
.nav-brand{font-family:'Bebas Neue',cursive;font-size:1.5rem;letter-spacing:.15em;color:var(--white)}
.nav-brand span{color:var(--gold)}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:.75rem;letter-spacing:.2em;color:rgba(245,240,232,.65);text-decoration:none;text-transform:uppercase;transition:color .3s;position:relative;cursor:none}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;right:0;height:1px;background:var(--gold);transform:scaleX(0);transition:transform .3s}
.nav-links a:hover,.nav-links a.active{color:var(--gold)}
.nav-links a:hover::after,.nav-links a.active::after{transform:scaleX(1)}
.nav-btn{background:var(--gold);color:var(--black);border:none;padding:.6rem 1.4rem;font-family:'Oswald',sans-serif;font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;cursor:none;font-weight:700;transition:all .3s}
.nav-btn:hover{background:var(--gold-light);transform:translateY(-2px);box-shadow:0 6px 20px rgba(201,168,76,.35)}
#hero{min-height:100vh;position:relative;display:flex;align-items:center;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:linear-gradient(160deg,rgba(10,10,10,.92) 0%,rgba(17,17,17,.85) 50%,rgba(10,10,10,.95) 100%),url('https://upload.wikimedia.org/wikipedia/commons/thumb/a/a9/T%C3%BCpra%C5%9F_Stadyumu_20231011_2.jpg/1280px-T%C3%BCpra%C5%9F_Stadyumu_20231011_2.jpg') center/cover no-repeat}
.hero-bg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(201,168,76,.12) 0%,transparent 60%),radial-gradient(ellipse at 20% 80%,rgba(204,34,34,.08) 0%,transparent 50%)}
.hero-pattern{position:absolute;inset:0;background-image:repeating-linear-gradient(45deg,transparent,transparent 60px,rgba(201,168,76,.025) 60px,rgba(201,168,76,.025) 61px)}
.hero-crest{position:absolute;right:4rem;top:50%;transform:translateY(-50%);width:min(38vw,520px);height:auto;opacity:.10;pointer-events:none;filter:drop-shadow(0 0 60px rgba(201,168,76,.3))}
.hero-content{position:relative;z-index:2;padding:0 4rem;max-width:820px}
.hero-badge{display:inline-flex;align-items:center;gap:.6rem;border:1px solid rgba(201,168,76,.4);padding:.4rem 1rem;font-size:.65rem;letter-spacing:.3em;color:var(--gold);text-transform:uppercase;margin-bottom:2rem;opacity:0;animation:fadeUp .8s .2s forwards}
.hero-badge::before{content:'';width:6px;height:6px;background:var(--gold);border-radius:50%;animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.6)}}
.hero-title{font-family:'Bebas Neue',cursive;font-size:clamp(4rem,10vw,10rem);line-height:.9;letter-spacing:.02em;margin-bottom:1.5rem;opacity:0;animation:fadeUp .8s .4s forwards}
.hero-title .line2{color:var(--gold);display:block}
.hero-sub{font-family:'Crimson Pro',serif;font-style:italic;font-size:1.25rem;color:rgba(245,240,232,.75);line-height:1.7;max-width:480px;margin-bottom:3rem;opacity:0;animation:fadeUp .8s .6s forwards}
.hero-ctas{display:flex;gap:1.2rem;flex-wrap:wrap;opacity:0;animation:fadeUp .8s .8s forwards}
.btn-primary{background:var(--gold);color:var(--black);border:none;padding:1rem 2.5rem;font-family:'Oswald',sans-serif;font-size:.8rem;letter-spacing:.25em;text-transform:uppercase;font-weight:700;cursor:none;transition:all .3s;text-decoration:none;display:inline-block}
.btn-primary:hover{background:var(--gold-light);transform:translateY(-3px);box-shadow:0 10px 30px rgba(201,168,76,.3)}
.btn-outline{border:1px solid rgba(245,240,232,.3);color:var(--white);padding:1rem 2.5rem;font-family:'Oswald',sans-serif;font-size:.8rem;letter-spacing:.25em;text-transform:uppercase;cursor:none;transition:all .3s;text-decoration:none;display:inline-block;background:transparent}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);transform:translateY(-3px)}
.hero-stats{position:absolute;right:4rem;bottom:4rem;display:flex;gap:3rem;opacity:0;animation:fadeUp .8s 1s forwards;z-index:2}
.stat{text-align:center}
.stat-num{font-family:'Bebas Neue',cursive;font-size:3rem;color:var(--gold);line-height:1;display:block}
.stat-label{font-size:.6rem;letter-spacing:.2em;color:rgba(245,240,232,.5);text-transform:uppercase;display:block;margin-top:.3rem}
.scroll-hint{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.5rem;color:rgba(245,240,232,.4);font-size:.6rem;letter-spacing:.3em;text-transform:uppercase;opacity:0;animation:fadeUp .8s 1.2s forwards;z-index:2}
.scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--gold),transparent);animation:scrollLine 2s ease-in-out infinite}
@keyframes scrollLine{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform:scaleY(1);transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}
@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
.ticker-wrap{background:var(--gold);overflow:hidden;padding:.65rem 0}
.ticker{display:flex;animation:ticker 35s linear infinite;white-space:nowrap}
.ticker-item{font-family:'Bebas Neue',cursive;font-size:1.05rem;color:var(--black);letter-spacing:.1em;padding:0 2rem}
.ticker-sep{color:rgba(10,10,10,.35)}
@keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.section-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.5rem}
.section-label{font-size:.62rem;letter-spacing:.35em;color:var(--gold);text-transform:uppercase;display:block;margin-bottom:.6rem}
.section-title{font-family:'Bebas Neue',cursive;font-size:clamp(2.5rem,5vw,4.5rem);line-height:1;letter-spacing:.03em}
.see-all{font-size:.68rem;letter-spacing:.2em;color:var(--gold);text-decoration:none;text-transform:uppercase;border-bottom:1px solid var(--gold);padding-bottom:2px;transition:opacity .3s;cursor:none}
.see-all:hover{opacity:.6}
.tabs{display:flex;gap:2px;margin-bottom:2.5rem;background:var(--mid);padding:4px;width:fit-content}
.tab-btn{font-family:'Oswald',sans-serif;font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,240,232,.5);background:transparent;border:none;padding:.6rem 1.4rem;cursor:none;transition:all .3s}
.tab-btn.active{background:var(--gold);color:var(--black);font-weight:700}
.tab-btn:not(.active):hover{color:var(--white)}
/* FIXTURES */
#fixtures{padding:6rem 4rem;background:var(--gray);position:relative}
#fixtures::before{content:'FIKSTÜR';position:absolute;right:2rem;top:2rem;font-family:'Bebas Neue',cursive;font-size:8rem;color:rgba(255,255,255,.018);letter-spacing:.1em;pointer-events:none}
.fixture-list{display:flex;flex-direction:column;gap:2px}
.fixture{display:grid;grid-template-columns:140px 1fr 130px 1fr 110px;align-items:center;gap:1.5rem;padding:1.4rem 2rem;background:var(--mid);border-left:3px solid transparent;transition:all .3s;cursor:none;position:relative;overflow:hidden}
.fixture::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,rgba(201,168,76,.06),transparent);opacity:0;transition:opacity .3s}
.fixture:hover{border-left-color:var(--gold);transform:translateX(6px)}
.fixture:hover::after{opacity:1}
.fixture.next{border-left-color:var(--gold);background:linear-gradient(90deg,rgba(201,168,76,.07),var(--mid))}
.fixture.hidden{display:none}
.fixture-date{font-size:.7rem;letter-spacing:.08em;color:rgba(245,240,232,.4);line-height:1.5}
.next-badge{display:block;font-size:.55rem;color:var(--gold);letter-spacing:.2em;font-weight:700;margin-top:3px}
.fixture-team{font-size:1rem;font-weight:600;letter-spacing:.04em}
.fixture-team.away{text-align:right}
.fixture-center{display:flex;flex-direction:column;align-items:center;gap:.2rem}
.fixture-score{font-family:'Bebas Neue',cursive;font-size:2rem;letter-spacing:.1em;line-height:1}
.fixture-score.win{color:var(--green)}.fixture-score.loss{color:var(--red)}.fixture-score.draw{color:rgba(245,240,232,.5)}
.fixture-vs{font-family:'Bebas Neue',cursive;font-size:1.6rem;color:var(--gold);letter-spacing:.1em}
.fixture-time{font-size:.75rem;color:var(--gold);font-weight:600}
.fixture-result{font-size:.55rem;letter-spacing:.15em;font-weight:700;padding:2px 6px;margin-top:2px}
.fixture-result.win{background:rgba(58,158,95,.2);color:var(--green)}
.fixture-result.loss{background:rgba(204,34,34,.2);color:var(--red)}
.fixture-result.draw{background:rgba(255,255,255,.08);color:rgba(245,240,232,.5)}
.fixture-league{font-size:.58rem;letter-spacing:.1em;color:rgba(245,240,232,.3);text-transform:uppercase;text-align:right;line-height:1.6}
/* SQUAD */
#squad{padding:6rem 4rem;background:var(--black)}
.squad-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:3px}
.player-card{position:relative;aspect-ratio:3/4;background:var(--gray);overflow:hidden;cursor:none}
.player-card::before{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,10,.95) 0%,rgba(10,10,10,.2) 55%,transparent 100%);z-index:1}
.pcard-border{position:absolute;inset:0;border:2px solid transparent;transition:border-color .4s;z-index:3;pointer-events:none}
.player-card:hover .pcard-border{border-color:var(--gold)}
.player-avatar{width:100%;height:100%;object-fit:cover;object-position:top center;transition:transform .5s ease;display:block;background:linear-gradient(135deg,#151515,#252525)}
.player-card:hover .player-avatar{transform:scale(1.07)}
.player-info{position:absolute;bottom:0;left:0;right:0;padding:1.5rem 1.2rem;z-index:2;transform:translateY(22px);transition:transform .4s ease}
.player-card:hover .player-info{transform:translateY(0)}
.player-num{font-family:'Bebas Neue',cursive;font-size:.95rem;color:var(--gold);letter-spacing:.05em;display:block}
.player-name{font-family:'Bebas Neue',cursive;font-size:1.35rem;letter-spacing:.05em;line-height:1.1}
.player-pos{font-size:.62rem;letter-spacing:.2em;color:rgba(245,240,232,.4);text-transform:uppercase;margin-top:.3rem;display:block}
.player-nat{position:absolute;top:1rem;right:1rem;font-size:1.3rem;z-index:2;filter:drop-shadow(0 2px 4px rgba(0,0,0,.8))}
.player-card.hidden{display:none}
.peek{position:absolute;bottom:0;left:0;right:0;background:rgba(10,10,10,.93);padding:.8rem 1.2rem;z-index:4;opacity:0;transition:opacity .3s;display:flex;justify-content:space-around}
.player-card:hover .peek{opacity:1}
.peek-stat{text-align:center}
.peek-val{font-family:'Bebas Neue',cursive;font-size:1.3rem;color:var(--gold);line-height:1;display:block}
.peek-key{font-size:.55rem;letter-spacing:.15em;color:rgba(245,240,232,.35);text-transform:uppercase;display:block;margin-top:2px}
/* NEWS */
#news{padding:6rem 4rem;background:var(--gray)}
.news-filter{display:flex;gap:2px;margin-bottom:2.5rem;flex-wrap:wrap}
.nfbtn{font-family:'Oswald',sans-serif;font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(245,240,232,.45);background:var(--mid);border:none;padding:.5rem 1.2rem;cursor:none;transition:all .3s}
.nfbtn.active{background:var(--gold);color:var(--black);font-weight:700}
.nfbtn:not(.active):hover{color:var(--white)}
.news-grid{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:auto auto;gap:3px}
.news-card{position:relative;overflow:hidden;background:var(--mid);cursor:none;transition:background .3s;min-height:230px}
.news-card.featured{grid-row:1/3}
.news-card:hover{background:#303030}
.news-inner{padding:2rem;height:100%;display:flex;flex-direction:column;justify-content:flex-end;min-height:210px;position:relative;z-index:2}
.news-card.featured .news-inner{min-height:480px}
.ncbg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .6s,opacity .4s;opacity:.55;z-index:0}
.news-card:hover .ncbg{transform:scale(1.07);opacity:.7}
.ncoverlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,10,.96) 0%,rgba(10,10,10,.55) 55%,rgba(10,10,10,.15) 100%);z-index:1}
.ncat{font-size:.58rem;letter-spacing:.3em;color:var(--gold);text-transform:uppercase;display:inline-block;margin-bottom:.6rem;border:1px solid rgba(201,168,76,.4);padding:2px 8px;background:rgba(10,10,10,.4)}
.ntitle{font-family:'Bebas Neue',cursive;font-size:1.45rem;line-height:1.1;letter-spacing:.03em;margin-bottom:.8rem}
.news-card.featured .ntitle{font-size:2.4rem}
.nmeta{font-size:.62rem;color:rgba(245,240,232,.45);letter-spacing:.1em}
.news-card.hidden{display:none}
/* STADIUM */
#stadium{padding:6rem 4rem;background:var(--black);display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.stadium-visual{position:relative;aspect-ratio:4/3;background:linear-gradient(135deg,#0f0f0f,#1c1c1c);overflow:hidden}
.stadium-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 1.2s ease;display:block}
.stadium-visual:hover .stadium-img{transform:scale(1.05)}
.stadium-vignette{position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,10,.85) 0%,rgba(10,10,10,.15) 50%,transparent 100%);z-index:1}
.stadium-label{position:absolute;bottom:1.5rem;left:1.5rem;font-family:'Bebas Neue',cursive;font-size:1.8rem;color:var(--gold);letter-spacing:.1em;z-index:2}
.stadium-stripe{position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--gold),var(--gold-light),var(--gold));z-index:2}
.stadium-info h2{font-family:'Bebas Neue',cursive;font-size:clamp(2rem,4vw,3.5rem);line-height:1;margin-bottom:1.5rem;letter-spacing:.03em}
.stadium-info p{font-family:'Crimson Pro',serif;font-size:1.1rem;line-height:1.8;color:rgba(245,240,232,.6);margin-bottom:2rem}
.stadium-facts{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.fact{border:1px solid rgba(201,168,76,.2);padding:1.2rem}
.fact-val{font-family:'Bebas Neue',cursive;font-size:2rem;color:var(--gold);display:block}
.fact-key{font-size:.62rem;letter-spacing:.15em;color:rgba(245,240,232,.35);text-transform:uppercase;display:block;margin-top:.2rem}
/* TITLES */
#titles{padding:5rem 4rem;background:var(--gold);color:var(--black);text-align:center;position:relative;overflow:hidden}
#titles::before{content:'';position:absolute;width:36rem;height:36rem;top:50%;left:50%;transform:translate(-50%,-50%);background:url('https://upload.wikimedia.org/wikipedia/commons/thumb/d/da/BesiktasJK-Logo.svg/330px-BesiktasJK-Logo.svg.png') center/contain no-repeat;opacity:.06;pointer-events:none}
#titles .section-label{color:rgba(10,10,10,.5)}
#titles .section-title{margin-bottom:3rem}
.titles-grid{display:flex;justify-content:center;gap:4rem;flex-wrap:wrap;position:relative;z-index:1}
.title-item{position:relative;z-index:1}
.title-count{font-family:'Bebas Neue',cursive;font-size:5rem;line-height:1;display:block}
.title-name{font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(10,10,10,.55);display:block}
.title-icon{font-size:1.4rem;margin-bottom:.5rem;display:block}
/* FOOTER */
footer{background:#040404;padding:4rem;border-top:1px solid rgba(201,168,76,.12)}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;margin-bottom:3rem}
.footer-logo-row{display:flex;align-items:center;gap:.8rem;margin-bottom:1rem}
.footer-logo-img{height:42px;width:auto}
.footer-logo{font-family:'Bebas Neue',cursive;font-size:2rem;letter-spacing:.15em;display:block}
.footer-logo span{color:var(--gold)}
.footer-tagline{font-family:'Crimson Pro',serif;font-style:italic;font-size:1rem;color:rgba(245,240,232,.35);line-height:1.6}
.footer-col h4{font-size:.68rem;letter-spacing:.25em;color:var(--gold);text-transform:uppercase;margin-bottom:1.5rem}
.footer-col ul{list-style:none}
.footer-col li{margin-bottom:.8rem}
.footer-col a{font-size:.85rem;color:rgba(245,240,232,.35);text-decoration:none;transition:color .3s;cursor:none}
.footer-col a:hover{color:var(--white)}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:2rem;border-top:1px solid rgba(201,168,76,.08)}
.footer-copy{font-size:.68rem;letter-spacing:.1em;color:rgba(245,240,232,.18)}
.social-links{display:flex;gap:1rem}
.social-link{width:36px;height:36px;border:1px solid rgba(201,168,76,.25);display:flex;align-items:center;justify-content:center;font-size:.85rem;color:rgba(245,240,232,.35);text-decoration:none;transition:all .3s;cursor:none}
.social-link:hover{border-color:var(--gold);color:var(--gold)}
/* REVEAL */
.reveal{opacity:0;transform:translateY(36px);transition:opacity .8s ease,transform .8s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-delay-1{transition-delay:.12s}.reveal-delay-2{transition-delay:.22s}.reveal-delay-3{transition-delay:.32s}.reveal-delay-4{transition-delay:.42s}
/* MODALS */
.modal-overlay{position:fixed;inset:0;background:rgba(5,5,5,.9);z-index:800;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .35s;backdrop-filter:blur(8px)}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--gray);border:1px solid rgba(201,168,76,.2);max-width:760px;width:calc(100% - 2rem);max-height:90vh;overflow-y:auto;position:relative;transform:translateY(30px);transition:transform .35s;scrollbar-width:thin;scrollbar-color:var(--gold) var(--mid)}
.modal-overlay.open .modal{transform:translateY(0)}
.modal-close{position:sticky;top:0;right:0;float:right;background:var(--mid2);border:none;color:var(--white);width:44px;height:44px;font-size:1.2rem;cursor:none;display:flex;align-items:center;justify-content:center;z-index:5;transition:background .3s}
.modal-close:hover{background:var(--gold);color:var(--black)}
.modal-header{padding:2.5rem 2.5rem 1.5rem;border-bottom:1px solid rgba(201,168,76,.1)}
.modal-label{font-size:.6rem;letter-spacing:.35em;color:var(--gold);text-transform:uppercase;display:block;margin-bottom:.5rem}
.modal-title{font-family:'Bebas Neue',cursive;font-size:2.6rem;letter-spacing:.04em;line-height:1}
.modal-body{padding:2rem 2.5rem 2.5rem}
/* TICKET */
.step-label{font-size:.7rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(245,240,232,.38);margin-bottom:1.2rem;display:block;padding-left:2px}
.ticket-matches{display:flex;flex-direction:column;gap:2px;margin-bottom:2rem}
.tmatch{display:flex;align-items:center;justify-content:space-between;padding:1.2rem 1.4rem;background:var(--mid2);border:2px solid transparent;cursor:none;transition:all .3s;gap:1rem}
.tmatch:hover{border-color:rgba(201,168,76,.3)}
.tmatch.selected{border-color:var(--gold);background:rgba(201,168,76,.07)}
.tm-teams{font-family:'Bebas Neue',cursive;font-size:1.35rem;letter-spacing:.05em}
.tm-date{font-size:.62rem;color:rgba(245,240,232,.38);letter-spacing:.1em;margin-top:3px}
.tm-price{font-family:'Bebas Neue',cursive;font-size:1.6rem;color:var(--gold);text-align:right}
.tm-price small{font-family:'Oswald',sans-serif;font-size:.58rem;letter-spacing:.1em;color:rgba(245,240,232,.3);display:block}
.seat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-bottom:2rem}
.seat-cat{padding:1.2rem;background:var(--mid2);border:2px solid transparent;cursor:none;transition:all .3s;text-align:center}
.seat-cat:hover{border-color:rgba(201,168,76,.3)}
.seat-cat.selected{border-color:var(--gold);background:rgba(201,168,76,.07)}
.sc-name{font-family:'Bebas Neue',cursive;font-size:1.1rem;letter-spacing:.05em;display:block}
.sc-price{color:var(--gold);font-size:.85rem;font-weight:600;display:block;margin-top:.3rem}
.sc-note{font-size:.6rem;color:rgba(245,240,232,.3);letter-spacing:.1em;margin-top:.25rem;display:block}
.qty-row{display:flex;align-items:center;gap:1.5rem;margin-bottom:2rem}
.qty-label{font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,240,232,.45)}
.qty-controls{display:flex;align-items:center;gap:.5rem}
.qty-btn{width:36px;height:36px;background:var(--mid2);border:1px solid rgba(201,168,76,.2);color:var(--white);font-size:1.1rem;cursor:none;transition:all .3s;display:flex;align-items:center;justify-content:center}
.qty-btn:hover{background:var(--gold);color:var(--black);border-color:var(--gold)}
.qty-num{font-family:'Bebas Neue',cursive;font-size:1.8rem;color:var(--gold);min-width:2rem;text-align:center}
.summary{background:var(--mid2);padding:1.5rem;margin-bottom:1.5rem;border-left:3px solid var(--gold)}
.sum-row{display:flex;justify-content:space-between;margin-bottom:.5rem;font-size:.8rem;color:rgba(245,240,232,.5)}
.sum-total{display:flex;justify-content:space-between;padding-top:.8rem;border-top:1px solid rgba(201,168,76,.15);font-size:1rem;font-weight:600}
.sum-total span:last-child{color:var(--gold);font-family:'Bebas Neue',cursive;font-size:1.6rem}
.buy-btn{width:100%;background:var(--gold);color:var(--black);border:none;padding:1.1rem;font-family:'Oswald',sans-serif;font-size:.85rem;letter-spacing:.25em;text-transform:uppercase;font-weight:700;cursor:none;transition:all .3s}
.buy-btn:hover{background:var(--gold-light);transform:translateY(-2px);box-shadow:0 8px 25px rgba(201,168,76,.35)}
.ticket-success{text-align:center;padding:2.5rem 0;display:none}
.ticket-success h3{font-family:'Bebas Neue',cursive;font-size:3rem;color:var(--gold);margin-bottom:.5rem}
.ticket-success p{font-family:'Crimson Pro',serif;font-size:1.1rem;color:rgba(245,240,232,.6);font-style:italic;line-height:1.8}
/* PLAYER MODAL */
.pm-top{display:flex;gap:2rem;margin-bottom:2rem;align-items:flex-start}
.pm-avatar{width:130px;height:130px;background:var(--mid2);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden}
.pm-avatar img{width:100%;height:100%;object-fit:cover;object-position:top center}
.pm-num{font-family:'Bebas Neue',cursive;font-size:1rem;color:var(--gold)}
.pm-name{font-family:'Bebas Neue',cursive;font-size:2.6rem;line-height:1;letter-spacing:.04em}
.pm-pos{font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,240,232,.4);margin-top:.3rem}
.pm-nat{font-size:1.4rem;margin-top:.6rem}
.pm-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-bottom:2rem}
.sbox{background:var(--mid2);padding:1.1rem;text-align:center}
.sbox-val{font-family:'Bebas Neue',cursive;font-size:2.1rem;color:var(--gold);line-height:1;display:block}
.sbox-key{font-size:.58rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(245,240,232,.3);display:block;margin-top:.25rem}
.pm-bio{font-family:'Crimson Pro',serif;font-size:1.05rem;line-height:1.85;color:rgba(245,240,232,.55);font-style:italic}
/* NEWS MODAL */
.nm-cat{font-size:.6rem;letter-spacing:.3em;color:var(--gold);text-transform:uppercase;display:inline-block;border:1px solid rgba(201,168,76,.3);padding:2px 8px;margin-bottom:1rem}
.nm-title{font-family:'Bebas Neue',cursive;font-size:clamp(1.8rem,4vw,3rem);line-height:1.05;letter-spacing:.03em;margin-bottom:.8rem}
.nm-meta{font-size:.65rem;color:rgba(245,240,232,.35);letter-spacing:.12em;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid rgba(201,168,76,.1)}
.nm-hero{background:var(--mid2);height:280px;margin-bottom:2rem;background-size:cover;background-position:center}
.nm-body p{font-family:'Crimson Pro',serif;font-size:1.1rem;line-height:1.9;color:rgba(245,240,232,.7);margin-bottom:1.4rem}
.nm-body strong{color:var(--white);font-style:normal;font-weight:400}
/* TOAST */
.toast{position:fixed;bottom:2rem;right:2rem;background:var(--gold);color:var(--black);padding:1rem 1.8rem;font-family:'Oswald',sans-serif;font-size:.8rem;letter-spacing:.15em;text-transform:uppercase;font-weight:700;z-index:1000;transform:translateY(120px);transition:transform .4s}
.toast.show{transform:translateY(0)}
@media(max-width:900px){
  nav{padding:1rem 1.5rem}.nav-links{display:none}
  .hero-content{padding:0 1.5rem}.hero-stats{right:1.5rem;gap:1.5rem}
  #fixtures,#squad,#news,#stadium,#titles,footer{padding:4rem 1.5rem}
  .news-grid{grid-template-columns:1fr}.news-card.featured{grid-row:auto}
  #stadium{grid-template-columns:1fr;gap:2rem}
  .footer-grid{grid-template-columns:1fr 1fr}
  .fixture{grid-template-columns:80px 1fr 90px 1fr;gap:.8rem}.fixture-league{display:none}
  .pm-stats{grid-template-columns:repeat(2,1fr)}.pm-top{flex-direction:column}
  .seat-grid{grid-template-columns:1fr 1fr}
}
</style>
